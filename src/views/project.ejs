<%- include('partials/header') %>
<%
    const friendlyDate = new Date(project.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
%>
<main class="page-shell project-page">
    <section class="page-intro">
        <p class="eyebrow">Service Project</p>
        <h1><%= project.title %></h1>
            <p><%= project.description %></p>
            <p>
                <% if (user && user.role === 'admin') { %>
                    <a href="/edit-project/<%= project.project_id %>" class="btn btn-sm btn-outline-primary">Edit Project</a>
                    <a href="/project/<%= project.project_id %>/assign-categories" class="btn btn-sm btn-outline-secondary">Edit Categories</a>
                <% } %>
            </p>
    </section>

    <section class="project-detail-section" aria-labelledby="project-detail-heading">
        <div class="section-heading">
            <h2 id="project-detail-heading">Project Details</h2>
        </div>

        <dl class="detail-list">
            <div>
                <dt>Date</dt>
                <dd><%= friendlyDate %></dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd><%= project.location %></dd>
            </div>
            <div>
                <dt>Partner Organization</dt>
                <dd>
                    <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                </dd>
            </div>
            <div>
                <dt>Categories</dt>
                <dd>
                    <% if (categories.length) { %>
                        <ul class="tag-list">
                            <% categories.forEach(category => { %>
                                <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        No categories assigned.
                    <% } %>
                </dd>
            </div>
        </dl>
    </section>
</main>
<%- include('partials/footer') %>
