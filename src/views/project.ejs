<%- include('partials/header') %>
<%
    const friendlyDate = new Date(project.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
%>
<main class="page-shell project-page">
    <section class="page-intro">
        <p class="eyebrow">Service Project</p>
        <h1><%= project.title %></h1>
        <p><%= project.description %></p>
    </section>

    <section class="project-detail-section" aria-labelledby="project-detail-heading">
        <div class="section-heading">
            <h2 id="project-detail-heading">Project Details</h2>
        </div>

        <dl class="detail-list">
            <div>
                <dt>Date</dt>
                <dd><%= friendlyDate %></dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd><%= project.location %></dd>
            </div>
            <div>
                <dt>Partner Organization</dt>
                <dd>
                    <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                </dd>
            </div>
        </dl>
    </section>
</main>
<%- include('partials/footer') %>
