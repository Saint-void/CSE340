<%- include('partials/header') %>
<main class="page-shell organizations-page">
    <section class="page-intro">
        <p class="eyebrow">Community Partners</p>
        <h1><%= title %></h1>
        <p>We are proud to collaborate with organizations that bring steady service, local care, and practical support to the community.</p>
    </section>

    <section class="organizations-section" aria-labelledby="organizations-heading">
        <div class="section-heading">
            <h2 id="organizations-heading">Partner Directory</h2>
            <p><%= organizations.length %> active partners</p>
        </div>

        <% if (organizations.length) { %>
            <ul class="organization-grid">
                <% organizations.forEach(org => { %>
                    <li class="organization-card">
                        <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> Logo">
                        <div class="organization-content">
                            <h3><a href="/organization/<%= org.organization_id %>"><%= org.name %></a></h3>
                            <p><%= org.description %></p>
                            <a href="mailto:<%= org.contact_email %>"><%= org.contact_email %></a>
                        </div>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="empty-state">No partner organizations are available right now.</p>
        <% } %>
    </section>

    <div>
        <% if (user && user.role === 'admin') { %>
            <a href="/new-organization">Add a new organization</a>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>
