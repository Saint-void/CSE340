<%- include('partials/header') %>

<div class="container mt-5">
    <h1><%= title %></h1>
    <h2><%= project.title %></h2>

    <form action="/project/<%= project.project_id %>/assign-categories" method="POST">
        <div class="mb-3">
            <% const assignedIds = (assignedCategories || []).map(c => c.category_id); %>
            <% categories.forEach(category => { %>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categoryIds" value="<%= category.category_id %>" id="cat-<%= category.category_id %>" <%= assignedIds.includes(category.category_id) ? 'checked' : '' %>>
                    <label class="form-check-label" for="cat-<%= category.category_id %>"><%= category.name %></label>
                </div>
            <% }) %>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/project/<%= project.project_id %>" class="btn btn-secondary">Cancel</a>
    </form>
</div>

<%- include('partials/footer') %>
