<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (users && users.length) { %>
        <table class="users-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.user_id %></td>
                        <td><%= u.name %></td>
                        <td><%= u.email %></td>
                        <td><%= u.role || 'user' %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No registered users found.</p>
    <% } %>
</main>
<%- include('partials/footer') %>
